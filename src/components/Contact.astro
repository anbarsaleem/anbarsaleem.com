---

<section class="contact" id="contact">
  <div class="contact-container">
    <h2>Get in Touch</h2>
    <div class="contact-links">
      {
        socials.map((s) => (
          <a
            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            class="contact-card"
            style={`--hover-color: ${s.color}`}
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d={s.icon} />
            </svg>
            <span>{s.label}</span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .contact {
    padding: 4rem 2rem 6rem;
    background: #00001a;
    color: #f8f8f8;
  }

  h2 {
    font-size: 1.8rem;
    text-align: center;
    margin-bottom: 2.5rem;
    position: relative;
  }

  h2::after {
    content: "";
    display: block;
    width: 200px;
    height: 2px;
    background: #f8f8f8;
    margin: 1rem auto 0;
  }

  .contact-container {
    max-width: 700px;
    margin: 0 auto;
  }

  .contact-links {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .contact-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1.25rem 1.5rem;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    text-decoration: none;
    color: #f8f8f8;
    transition:
      background 0.3s,
      transform 0.2s;
    min-width: 100px;
  }

  .contact-card:hover {
    background: var(--hover-color);
    transform: translateY(-4px);
  }

  .contact-card svg {
    width: 28px;
    height: 28px;
  }

  .contact-card span {
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  @media (max-width: 480px) {
    .contact-links {
      gap: 1rem;
    }
    .contact-card {
      padding: 1rem;
      min-width: 80px;
    }
  }
</style>
