---

<section class="about" id="about">
  <div class="about-container">
    <h2>About Me</h2>
    <div class="about-content">
      <div class="photo-wrapper">
        <div class="img-with-txt" id="img-with-txt">
          <img
            src="/img/anbar_new_suit_pic.png"
            alt="Anbar Saleem"
            class="profile-pic"
            id="profile-pic"
          />
          <div class="overlay-txt" id="overlay-txt">Hi there! It's me, Anbar.</div>
        </div>
      </div>
      <div class="bio">
        <p>
          Hardworker, Tenor II Singer (Men's Choir and Shower), Lefty, and Super
          Mario Enthusiast
        </p>
        <p>
          I am currently a Software Engineer at <b>AT&T</b> and alumni from
          <b>New Jersey Institute of Technology's Albert Dorman Honors College</b>
          with a Bachelor's Degree in <b>Computer Science</b>. I am also
          currently pursuing my <b>Master's in Computer Science at Georgia Tech</b>
          through the OMSCS program.
        </p>
        <p>
          Outside of work and school, I run a multi-node
          <a href="https://github.com/anbarsaleem/homelab" target="_blank" rel="noopener noreferrer">homelab</a>,
          make videos about homelabbing and developer tooling, and pursue different
          personal projects located on my
          <a href="https://github.com/anbarsaleem" target="_blank" rel="noopener noreferrer">Github</a>
          profile, including this here website :). The purpose of these
          endeavors is to help further strengthen my programming arsenal as well as
          be ways for me to spend my time in both a fun and productive manner.
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  const pic = document.getElementById("profile-pic")!;
  const txt = document.getElementById("overlay-txt")!;

  pic.addEventListener("mouseenter", () => {
    txt.style.display = "block";
  });
  pic.addEventListener("mouseleave", () => {
    txt.style.display = "none";
  });
</script>

<style>
  .about {
    padding: 6rem 2rem 4rem;
    background: #f8f8f8;
  }

  h2 {
    font-size: 1.8rem;
    text-align: center;
    margin-bottom: 2rem;
    position: relative;
  }

  h2::after {
    content: "";
    display: block;
    width: 200px;
    height: 2px;
    background: #00001a;
    margin: 1rem auto 0;
  }

  .about-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .about-content {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .photo-wrapper {
    flex-shrink: 0;
  }

  .img-with-txt {
    position: relative;
    text-align: center;
  }

  .profile-pic {
    width: 180px;
    height: 180px;
    border-radius: 50px;
    border: 3px solid #00001a;
    object-fit: cover;
    cursor: pointer;
    transition: opacity 0.3s;
  }

  .overlay-txt {
    display: none;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    color: #00001a;
    font-weight: 500;
    font-size: 0.85rem;
    pointer-events: none;
  }

  .img-with-txt:hover .profile-pic {
    opacity: 0.6;
  }

  .bio {
    font-size: 0.9rem;
    line-height: 1.7;
    color: #1e2a45;
    font-weight: 400;
    text-align: justify;
  }

  .bio p + p {
    margin-top: 0.75rem;
  }

  .bio a {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  @media (max-width: 640px) {
    .about-content {
      flex-direction: column;
      text-align: center;
    }

    .bio {
      text-align: center;
    }

    .profile-pic {
      width: 140px;
      height: 140px;
    }
  }
</style>
