---
import projects from "../../public/projects.json";

const LANG_COLORS: Record<string, string> = {
  JavaScript: "#D8C84F",
  TypeScript: "#007acc",
  Python: "#306999",
  Go: "#00ADD8",
  Java: "#B07219",
  HTML: "#E34C26",
  CSS: "#563D7C",
  "C++": "#f34b7d",
  C: "#555555",
  "C#": "#178600",
  Swift: "#FFAC45",
  Ruby: "#CC342D",
  Shell: "#89e051",
  Dockerfile: "#384d54",
  HCL: "#844FBA",
  Vue: "#4FC08D",
  Nix: "#7e7eff",
  Astro: "#ff5a03",
  Jinja: "#a52a22",
  Makefile: "#427819",
  Pug: "#a86454",
};
---

<section class="projects" id="projects">
  <div class="projects-container">
    <h2>Programming Projects</h2>
    <p class="projects-intro">
      A selection of projects from my Github profile, sorted by most recently
      worked on. Feel free to check them out or reach out with any questions.
    </p>
    <div class="projects-grid" id="projects-grid">
      {projects.map((repo) => {
        return (
          <a
            class="project-card"
            href={repo.html_url}
            target="_blank"
            rel="noopener noreferrer"
          >
            <div class="card-body">
              <h3 class="card-title">{repo.name}</h3>
              <p class="card-desc">{repo.description}</p>
            </div>
            <div class="card-footer">
              <div class="lang-tags-wrap">
                <div class="lang-tags collapsed">
                  {repo.languages.map((l: string) => (
                    <span
                      class="lang-tag"
                      style={`--lang-color:${LANG_COLORS[l] || "#666"}`}
                    >
                      {l}
                    </span>
                  ))}
                </div>
              </div>
              <span class="card-arrow">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M7 17L17 7M17 7H7M17 7v10"/>
                </svg>
              </span>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>

<script>
  function visibleTagCount(container: HTMLElement): number {
    const tags = container.querySelectorAll(".lang-tag");
    const containerTop = container.getBoundingClientRect().top;
    const cutoff = containerTop + container.offsetHeight;
    let count = 0;
    tags.forEach((tag) => {
      if (tag.getBoundingClientRect().top < cutoff) count++;
    });
    return count;
  }

  document.querySelectorAll(".lang-tags").forEach((tagsContainer) => {
    const tagsWrap = tagsContainer.parentElement!;
    requestAnimationFrame(() => {
      if (tagsContainer.scrollHeight > tagsContainer.offsetHeight + 2) {
        const moreBtn = document.createElement("button");
        moreBtn.className = "lang-more";
        const hiddenCount =
          tagsContainer.querySelectorAll(".lang-tag").length -
          visibleTagCount(tagsContainer);
        moreBtn.textContent = `+${hiddenCount}`;
        moreBtn.addEventListener("click", (e) => {
          e.preventDefault();
          e.stopPropagation();
          const expanded = tagsContainer.classList.toggle("expanded");
          tagsContainer.classList.toggle("collapsed", !expanded);
          moreBtn.textContent = expanded ? "less" : `+${hiddenCount}`;
        });
        tagsWrap.appendChild(moreBtn);
      }
    });
  });
</script>

<style>
  .projects {
    padding: 4rem 2rem;
    background: white;
  }

  h2 {
    font-size: 1.8rem;
    text-align: center;
    margin-bottom: 1rem;
    position: relative;
  }

  h2::after {
    content: "";
    display: block;
    width: 200px;
    height: 2px;
    background: #00001a;
    margin: 1rem auto 0;
  }

  .projects-container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .projects-intro {
    text-align: center;
    font-size: 0.85rem;
    color: #666;
    margin-bottom: 2.5rem;
  }
</style>

<style is:global>
  #projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  #projects-grid .loading,
  #projects-grid .error {
    text-align: center;
    font-size: 0.85rem;
    color: #888;
    grid-column: 1 / -1;
  }

  #projects-grid .project-card {
    display: flex;
    flex-direction: column;
    min-height: 200px;
    background: #fafafa;
    border: 1px solid #e8e8e8;
    border-radius: 12px;
    padding: 1.5rem;
    text-decoration: none;
    color: #1e2a45;
    transition:
      transform 0.2s,
      box-shadow 0.2s,
      border-color 0.2s;
    cursor: pointer;
  }

  #projects-grid .project-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
    border-color: #618985;
  }

  #projects-grid .card-body {
    flex: 1;
  }

  #projects-grid .card-title {
    font-size: 0.95rem;
    font-weight: 600;
    margin: 0 0 0.6rem;
    color: #1e2a45;
  }

  #projects-grid .card-desc {
    font-size: 0.8rem;
    color: #555;
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  #projects-grid .card-footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 0.75rem;
    gap: 0.75rem;
  }

  #projects-grid .lang-tags-wrap {
    display: flex;
    align-items: flex-end;
    gap: 0.4rem;
    min-width: 0;
    flex: 1;
  }

  #projects-grid .lang-tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  #projects-grid .lang-tags.collapsed {
    max-height: 22px;
    overflow: hidden;
  }

  #projects-grid .lang-tags.expanded {
    max-height: none;
  }

  #projects-grid .lang-tag {
    font-size: 0.55rem;
    text-transform: uppercase;
    color: var(--lang-color);
    padding: 2px 8px;
    border: 1px solid var(--lang-color);
    border-radius: 100px;
    font-weight: 700;
    letter-spacing: 0.5px;
    background: transparent;
    white-space: nowrap;
  }

  #projects-grid .lang-more {
    flex-shrink: 0;
    font-size: 0.55rem;
    font-weight: 700;
    font-family: "Lato", Arial, sans-serif;
    color: #618985;
    background: none;
    border: 1px solid #618985;
    border-radius: 100px;
    padding: 2px 8px;
    cursor: pointer;
    letter-spacing: 0.5px;
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;
  }

  #projects-grid .lang-more:hover {
    background: #618985;
    color: white;
  }

  #projects-grid .card-arrow {
    flex-shrink: 0;
    color: #bbb;
    transition: color 0.2s;
  }

  #projects-grid .project-card:hover .card-arrow {
    color: #618985;
  }

  @media (max-width: 640px) {
    #projects-grid {
      grid-template-columns: 1fr;
    }

    #projects-grid .project-card {
      padding: 1.25rem;
    }
  }
</style>
