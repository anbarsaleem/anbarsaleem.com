---

---

<section class="projects" id="projects">
  <div class="projects-container">
    <h2>Programming Projects</h2>
    <p class="projects-intro">
      A selection of projects from my Github profile, sorted by most recently
      worked on. Feel free to check them out or reach out with any questions.
    </p>
    <div class="projects-grid" id="projects-grid">
      <p class="loading">Loading projects...</p>
    </div>
  </div>
</section>

<script>
  const LANG_COLORS: Record<string, string> = {
    JavaScript: "#D8C84F",
    TypeScript: "#007acc",
    Python: "#306999",
    Go: "#00ADD8",
    Java: "#B07219",
    HTML: "#E34C26",
    CSS: "#563D7C",
    "C++": "#f34b7d",
    C: "#555555",
    "C#": "#178600",
    Swift: "#FFAC45",
    Ruby: "#CC342D",
    Shell: "#89e051",
    Dockerfile: "#384d54",
    HCL: "#844FBA",
    Vue: "#4FC08D",
    Nix: "#7e7eff",
    Astro: "#ff5a03",
    Jinja: "#a52a22",
    Makefile: "#427819",
    Pug: "#a86454",
  };

  const USERNAME = "anbarsaleem";

  async function loadProjects() {
    const grid = document.getElementById("projects-grid")!;
    try {
      const res = await fetch(
        `https://api.github.com/users/${USERNAME}/repos?type=all&sort=pushed&direction=desc&per_page=50`
      );
      const repos = await res.json();
      const publicRepos = repos.filter(
        (r: any) => !r.private && r.description
      );

      const contributorChecks = await Promise.all(
        publicRepos.map(async (repo: any) => {
          try {
            const contribRes = await fetch(
              `https://api.github.com/repos/${USERNAME}/${repo.name}/contributors?per_page=30`
            );
            const contribs = await contribRes.json();
            const isContrib =
              Array.isArray(contribs) &&
              contribs.some(
                (c: any) => c.login?.toLowerCase() === USERNAME
              );
            return isContrib ? repo : null;
          } catch {
            return null;
          }
        })
      );
      const filtered = contributorChecks.filter(Boolean);

      grid.innerHTML = "";

      for (const repo of filtered) {
        const langRes = await fetch(repo.languages_url);
        const languages = await langRes.json();
        const langNames = Object.keys(languages);

        const card = document.createElement("a");
        card.className = "project-card";
        card.href = repo.html_url;
        card.target = "_blank";
        card.rel = "noopener noreferrer";

        card.innerHTML = `
          <div class="card-body">
            <h3 class="card-title">${repo.name}</h3>
            <p class="card-desc">${repo.description || ""}</p>
          </div>
          <div class="card-footer">
            <div class="lang-tags">
              ${langNames
                .map(
                  (l: string) =>
                    `<span class="lang-tag" style="--lang-color:${LANG_COLORS[l] || "#666"}">${l}</span>`
                )
                .join("")}
            </div>
            <span class="card-arrow">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 17L17 7M17 7H7M17 7v10"/>
              </svg>
            </span>
          </div>
        `;

        grid.appendChild(card);
      }
    } catch {
      grid.innerHTML = '<p class="error">Could not load projects.</p>';
    }
  }

  loadProjects();
</script>

<style>
  .projects {
    padding: 4rem 2rem;
    background: white;
  }

  h2 {
    font-size: 1.8rem;
    text-align: center;
    margin-bottom: 1rem;
    position: relative;
  }

  h2::after {
    content: "";
    display: block;
    width: 200px;
    height: 2px;
    background: #00001a;
    margin: 1rem auto 0;
  }

  .projects-container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .projects-intro {
    text-align: center;
    font-size: 0.85rem;
    color: #666;
    margin-bottom: 2.5rem;
  }
</style>

<style is:global>
  #projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  #projects-grid .loading,
  #projects-grid .error {
    text-align: center;
    font-size: 0.85rem;
    color: #888;
    grid-column: 1 / -1;
  }

  #projects-grid .project-card {
    display: flex;
    flex-direction: column;
    background: #fafafa;
    border: 1px solid #e8e8e8;
    border-radius: 12px;
    padding: 1.5rem;
    text-decoration: none;
    color: #1e2a45;
    transition:
      transform 0.2s,
      box-shadow 0.2s,
      border-color 0.2s;
    cursor: pointer;
  }

  #projects-grid .project-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
    border-color: #618985;
  }

  #projects-grid .card-body {
    flex: 1;
  }

  #projects-grid .card-title {
    font-size: 0.95rem;
    font-weight: 600;
    margin: 0 0 0.6rem;
    color: #1e2a45;
  }

  #projects-grid .card-desc {
    font-size: 0.8rem;
    color: #555;
    line-height: 1.6;
    margin: 0;
  }

  #projects-grid .card-footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-top: 1.25rem;
    gap: 0.75rem;
  }

  #projects-grid .lang-tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  #projects-grid .lang-tag {
    font-size: 0.55rem;
    text-transform: uppercase;
    color: var(--lang-color);
    padding: 2px 8px;
    border: 1px solid var(--lang-color);
    border-radius: 100px;
    font-weight: 700;
    letter-spacing: 0.5px;
    background: transparent;
  }

  #projects-grid .card-arrow {
    flex-shrink: 0;
    color: #bbb;
    transition: color 0.2s;
  }

  #projects-grid .project-card:hover .card-arrow {
    color: #618985;
  }

  @media (max-width: 640px) {
    #projects-grid {
      grid-template-columns: 1fr;
    }

    #projects-grid .project-card {
      padding: 1.25rem;
    }
  }
</style>
