---

<section class="projects" id="projects">
  <div class="projects-container">
    <h2>Programming Projects</h2>
    <p class="projects-intro">
      Each button shows a project that is hosted on my Github profile. If you
      have any questions about any of them, please feel free to contact me.
      Click the buttons to toggle the projects displayed. :)
    </p>
    <div class="projects-list" id="projects-list">
      <p class="loading">Loading projects...</p>
    </div>
  </div>
</section>

<script>
  const LANG_COLORS: Record<string, string> = {
    JavaScript: "#D8C84F",
    TypeScript: "#007acc",
    Python: "#306999",
    Go: "#00ADD8",
    Java: "#B07219",
    HTML: "#E34C26",
    CSS: "#563D7C",
    "C++": "#f34b7d",
    C: "#555555",
    "C#": "#178600",
    Swift: "#FFAC45",
    Ruby: "#CC342D",
    Shell: "#89e051",
    Dockerfile: "#384d54",
    HCL: "#844FBA",
    Vue: "#4FC08D",
    Nix: "#7e7eff",
  };

  async function loadProjects() {
    const list = document.getElementById("projects-list")!;
    try {
      const res = await fetch(
        "https://api.github.com/users/anbarsaleem/repos?type=all&sort=pushed&direction=desc&per_page=30"
      );
      const repos = await res.json();
      const publicRepos = repos.filter(
        (r: any) => !r.fork && !r.private && r.description
      );

      list.innerHTML = "";

      for (const repo of publicRepos) {
        const langRes = await fetch(repo.languages_url);
        const languages = await langRes.json();
        const langNames = Object.keys(languages);

        const wrapper = document.createElement("div");
        wrapper.className = "project-wrapper";

        const button = document.createElement("button");
        button.className = "project-toggle";
        button.textContent = repo.name;

        const card = document.createElement("div");
        card.className = "project-card";
        card.innerHTML = `
          <div class="project-content">
            <div class="project-title">
              <h3>${repo.name}</h3>
              <div class="lang-tags">
                ${langNames
                  .map(
                    (l: string) =>
                      `<span class="lang-tag" style="background:${LANG_COLORS[l] || "#666"}">${l}</span>`
                  )
                  .join("")}
              </div>
            </div>
            <p class="project-desc">${repo.description || ""}</p>
            <div class="project-footer">
              <a href="${repo.html_url}" target="_blank" rel="noopener noreferrer" class="project-link">
                GITHUB
              </a>
            </div>
          </div>
        `;

        button.addEventListener("click", () => {
          const isVisible = card.classList.contains("visible");
          card.classList.toggle("visible");
          button.classList.toggle("active");
          card.style.maxHeight = isVisible ? "0" : card.scrollHeight + "px";
        });

        wrapper.appendChild(button);
        wrapper.appendChild(card);
        list.appendChild(wrapper);
      }
    } catch {
      list.innerHTML = '<p class="error">Could not load projects.</p>';
    }
  }

  loadProjects();
</script>

<style>
  .projects {
    padding: 4rem 2rem;
    background: white;
  }

  h2 {
    font-size: 1.8rem;
    text-align: center;
    margin-bottom: 1rem;
    position: relative;
  }

  h2::after {
    content: "";
    display: block;
    width: 200px;
    height: 2px;
    background: #00001a;
    margin: 1rem auto 0;
  }

  .projects-container {
    max-width: 800px;
    margin: 0 auto;
  }

  .projects-intro {
    text-align: center;
    font-size: 0.85rem;
    color: #666;
    margin-bottom: 2rem;
  }
</style>

<style is:global>
  #projects-list {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  #projects-list .loading,
  #projects-list .error {
    text-align: center;
    font-size: 0.85rem;
    color: #888;
  }

  #projects-list .project-wrapper {
    width: 100%;
    max-width: 700px;
  }

  #projects-list .project-toggle {
    width: 100%;
    padding: 0.75rem 1.25rem;
    font-family: "Lato", Arial, sans-serif;
    font-size: 0.85rem;
    font-weight: 400;
    color: #1e2a45;
    background: white;
    border: 1px solid #618985;
    border-radius: 4px;
    cursor: pointer;
    transition:
      background 0.2s,
      color 0.2s;
    letter-spacing: 0.5px;
  }

  #projects-list .project-toggle:hover {
    background: #618985;
    color: white;
  }

  #projects-list .project-toggle.active {
    background: #618985;
    color: white;
    border-radius: 4px 4px 0 0;
  }

  #projects-list .project-card {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease;
  }

  #projects-list .project-content {
    background: white;
    padding: 1.5rem 1.75rem;
    border-radius: 0 0 4px 4px;
    box-shadow: 0 10px 10px 5px rgba(0, 0, 0, 0.15);
    margin-bottom: 0.5rem;
  }

  #projects-list .project-title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  #projects-list .project-title h3 {
    font-size: 1rem;
    font-weight: 400;
    margin: 0;
    margin-right: auto;
  }

  #projects-list .lang-tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  #projects-list .lang-tag {
    font-size: 0.55rem;
    text-transform: uppercase;
    color: white;
    padding: 2px 8px;
    border-radius: 100px;
    font-weight: 700;
    letter-spacing: 0.5px;
  }

  #projects-list .project-desc {
    font-size: 0.8rem;
    color: #444;
    line-height: 1.7;
    margin-bottom: 1.25rem;
    font-weight: 400;
  }

  #projects-list .project-footer {
    display: flex;
    margin-top: auto;
  }

  #projects-list .project-link {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    text-decoration: none;
    color: #1e2a45;
    letter-spacing: 1px;
    transition: color 0.2s;
  }

  #projects-list .project-link:hover {
    color: #618985;
  }

  @media (max-width: 640px) {
    #projects-list .project-content {
      padding: 1.25rem;
    }
  }
</style>
